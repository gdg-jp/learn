{
  "$schema": "https://biomejs.dev/schemas/2.5.1/schema.json",
  "files": {
    "ignoreUnknown": true,
    "includes": ["**", "!dist", "!node_modules", "!serviceAccount.json"]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended"
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always",
      "trailingCommas": "none"
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  }
}
